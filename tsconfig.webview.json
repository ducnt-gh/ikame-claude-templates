{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "./out/webview",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["src/webview/**/*.ts", "src/webview/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
